{
    "name": "zarathustra-playground",
    "framework": null,
    "buildCommand": null,
    "outputDirectory": "public",
    "installCommand": null,
    "routes": [
        { "src": "/", "dest": "/index.html" },
        { "src": "/(.*)", "dest": "/$1" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        }
    ],
    "overrides": {
        "index.html": { "contentType": "text/html" },
        "demo.html": { "contentType": "text/html" },
        "docs.html": { "contentType": "text/html" }
    }
}
