{
    "name": "zarathustra-playground",
    "version": 2,
    "framework": null,
    "buildCommand": null,
    "outputDirectory": "public",
    "installCommand": null,
    "routes": [
        { "src": "/(.*)", "dest": "/index.html" }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
            ]
        }
    ]
}
