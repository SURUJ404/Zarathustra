{
    "functions": {
        "api/index.js": {
            "memory": 512,
            "maxDuration": 30,
            "includeFiles": "api/**"
        }
    },
    "outputDirectory": "public",
    "routes": [
        { "src": "/api/(.*)", "dest": "/api/index.js" },
        { "src": "/(.*)", "dest": "/$1" }
    ]
}
